#!/bin/bash


BLENDER_DIR="{{ .blender.blender_dir }}"
GENERIC_STARTUP="$HOME/.config/blender/blender-config/scripts/startup"

# Ensure our generic repository source directory path exists
mkdir -p "$GENERIC_STARTUP"

# Loop through any version-specific folders Steam/Blender has initialized
for version_dir in "$BLENDER_DIR"/[0-9].*; do
    if [ -d "$version_dir" ]; then
        TARGET_STARTUP_DIR="$version_dir/scripts/startup"
        
        # Ensure the native startup folder exists safely
        mkdir -p "$TARGET_STARTUP_DIR"
        
        # Create a targeted symlink for JUST our chezmoi folder inside it
        if [ ! -L "$TARGET_STARTUP_DIR/chezmoi" ]; then
            # Clean up if a legacy broken symlink or accidental file exists there
            rm -f "$TARGET_STARTUP_DIR/chezmoi" 
            
            ln -s "$GENERIC_STARTUP" "$TARGET_STARTUP_DIR/chezmoi"
            echo "🔗 Safely nested chezmoi startup tracking into: $TARGET_STARTUP_DIR/chezmoi"
        fi
    fi
done
